# Database URL for Neon Postgres
# Get this from your Neon dashboard: https://console.neon.tech/
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Optional: API key for additional security (recommended if exposing publicly)
# If set, API requests must include this in the header: x-api-key: YOUR_API_KEY
API_KEY=
